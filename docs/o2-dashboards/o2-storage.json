{
	"title": "dtvmgr Storage",
	"description": "Storage usage per recording/encode directory (dtvmgr.storage.* OTel metrics).",
	"defaultDatetimeDuration": {
		"type": "relative",
		"relativeTimePeriod": "3h"
	},
	"tabs": [
		{
			"tabId": "1",
			"name": "Storage",
			"panels": [
				{
					"id": "1",
					"type": "area-stacked",
					"title": "Directory Used (GB)",
					"description": "Per-directory used bytes (file size sum), stacked by path.",
					"layout": { "x": 0, "y": 0, "w": 96, "h": 23, "i": 1 },
					"config": { "show_legends": true, "unit": "bytes" },
					"queryType": "sql",
					"queries": [
						{
							"customQuery": true,
							"query": "SELECT histogram(_timestamp, '5 minutes') AS ts, AVG(value) AS used_bytes, path FROM \"dtvmgr_storage_used_bytes\" WHERE path IS NOT NULL GROUP BY ts, path ORDER BY ts",
							"fields": {
								"stream": "dtvmgr_storage_used_bytes",
								"stream_type": "metrics",
								"x": [{ "label": "ts", "alias": "ts", "column": "ts" }],
								"y": [
									{
										"label": "used_bytes",
										"alias": "used_bytes",
										"column": "used_bytes"
									}
								],
								"z": [],
								"breakdown": [
									{ "label": "path", "alias": "path", "column": "path" }
								],
								"filter": {
									"type": "list",
									"values": [],
									"logicalOperator": "AND",
									"filterType": "list"
								}
							},
							"config": { "promql_legend": "" }
						}
					]
				},
				{
					"id": "2",
					"type": "line",
					"title": "Directory Usage %",
					"description": "Per-directory usage ratio against total filesystem capacity.",
					"layout": { "x": 96, "y": 0, "w": 96, "h": 23, "i": 2 },
					"config": { "show_legends": true, "unit": "percent-1" },
					"queryType": "sql",
					"queries": [
						{
							"customQuery": true,
							"query": "SELECT histogram(_timestamp, '5 minutes') AS ts, AVG(value) AS usage_ratio, path FROM \"dtvmgr_storage_usage_ratio\" WHERE path IS NOT NULL GROUP BY ts, path ORDER BY ts",
							"fields": {
								"stream": "dtvmgr_storage_usage_ratio",
								"stream_type": "metrics",
								"x": [{ "label": "ts", "alias": "ts", "column": "ts" }],
								"y": [
									{
										"label": "usage_ratio",
										"alias": "usage_ratio",
										"column": "usage_ratio"
									}
								],
								"z": [],
								"breakdown": [
									{ "label": "path", "alias": "path", "column": "path" }
								],
								"filter": {
									"type": "list",
									"values": [],
									"logicalOperator": "AND",
									"filterType": "list"
								}
							},
							"config": { "promql_legend": "" }
						}
					]
				},
				{
					"id": "3",
					"type": "line",
					"title": "Filesystem Free (GB)",
					"description": "Filesystem-level free space. Same value for dirs on the same mount.",
					"layout": { "x": 0, "y": 23, "w": 96, "h": 23, "i": 3 },
					"config": { "show_legends": true, "unit": "bytes" },
					"queryType": "sql",
					"queries": [
						{
							"customQuery": true,
							"query": "SELECT histogram(_timestamp, '5 minutes') AS ts, AVG(value) AS free_bytes, path FROM \"dtvmgr_storage_free_bytes\" WHERE path IS NOT NULL GROUP BY ts, path ORDER BY ts",
							"fields": {
								"stream": "dtvmgr_storage_free_bytes",
								"stream_type": "metrics",
								"x": [{ "label": "ts", "alias": "ts", "column": "ts" }],
								"y": [
									{
										"label": "free_bytes",
										"alias": "free_bytes",
										"column": "free_bytes"
									}
								],
								"z": [],
								"breakdown": [
									{ "label": "path", "alias": "path", "column": "path" }
								],
								"filter": {
									"type": "list",
									"values": [],
									"logicalOperator": "AND",
									"filterType": "list"
								}
							},
							"config": { "promql_legend": "" }
						}
					]
				},
				{
					"id": "4",
					"type": "line",
					"title": "File Count",
					"description": "Number of regular files per directory.",
					"layout": { "x": 96, "y": 23, "w": 96, "h": 23, "i": 4 },
					"config": { "show_legends": true },
					"queryType": "sql",
					"queries": [
						{
							"customQuery": true,
							"query": "SELECT histogram(_timestamp, '5 minutes') AS ts, AVG(value) AS file_count, path FROM \"dtvmgr_storage_file_count\" WHERE path IS NOT NULL GROUP BY ts, path ORDER BY ts",
							"fields": {
								"stream": "dtvmgr_storage_file_count",
								"stream_type": "metrics",
								"x": [{ "label": "ts", "alias": "ts", "column": "ts" }],
								"y": [
									{
										"label": "file_count",
										"alias": "file_count",
										"column": "file_count"
									}
								],
								"z": [],
								"breakdown": [
									{ "label": "path", "alias": "path", "column": "path" }
								],
								"filter": {
									"type": "list",
									"values": [],
									"logicalOperator": "AND",
									"filterType": "list"
								}
							},
							"config": { "promql_legend": "" }
						}
					]
				}
			]
		}
	],
	"variables": { "list": [] }
}
